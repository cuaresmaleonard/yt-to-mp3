# Shared
APP_ENV=development
MAX_VIDEO_SECONDS=900
DOWNLOAD_TTL_SECONDS=3600
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380

# Backend
BACKEND_PORT=4000
DATABASE_URL=postgresql://app:app@postgres:5432/yttomp3
REDIS_URL=redis://redis:6379
QUEUE_NAME=convert-jobs
GUEST_COOKIE_SECRET=replace-me
TOKEN_SECRET=replace-me
GUEST_RATE_LIMIT_PER_HOUR=3
USER_RATE_LIMIT_PER_HOUR=15

# Worker
WORKER_CONCURRENCY=2
YT_DLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg
OUTPUT_DIR=/tmp/yt-to-mp3

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
